# Copy to .env and fill in values. Do not commit .env (see repo .gitignore).

# Receipt AI: gemini | claude
AI_PROVIDER=gemini

# Gemini (required when AI_PROVIDER=gemini). GOOGLE_API_KEY is an accepted alias.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Anthropic (required when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=

# Supabase (required for auth and persisted splits)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SESSIONS_TABLE=split_sessions

# Optional: Redis URL for shared session state (e.g. docker-compose). If unset, memory + Supabase only.
REDIS_URL=

# Optional tuning
MAX_IMAGE_SIZE_MB=10
MAX_IMAGES_PER_REQUEST=3
SESSION_TTL_DAYS=7
